{
	"name": "infra",
	"version": "1.0.0",
	"scripts": {
		"build": "tsc",
		"bootstrap": "cdk bootstrap",
		"bootstrap:prod": "cdk bootstrap --context env=prod",
		"synth": "cdk synth --no-staging",
		"synth:prod": "cdk synth --no-staging --context env=prod",
		"deploy": "cdk deploy --all --require-approval never",
		"deploy:tables": "cdk deploy Aerostack-TablesStack --require-approval never",
		"deploy:api": "cdk deploy Aerostack-ApiStack --require-approval never",
		"deploy:hiring": "cdk deploy Aerostack-HiringApiStack --require-approval never",
		"deploy:prod": "cdk deploy --all --context env=prod --require-approval never",
		"deploy:rbac-phase2": "cdk deploy --all --require-approval never --context rbac_mode=claims_then_db",
		"deploy:rbac-phase3": "cdk deploy --all --require-approval never --context rbac_mode=claims_only",
		"diff": "cdk diff",
		"openapi:local": "npm run synth && cat openapi-specs/openapi-dev.json",
		"openapi:local:prod": "npm run synth:prod && cat openapi-specs/openapi-prod.json",
		"openapi:validate": "npm run synth && npx @redocly/cli lint openapi-specs/openapi-dev.json",
		"local:db": "docker compose up -d",
		"local:init": "npx ts-node scripts/init-local-db.ts",
		"local:setup": "pnpm run local:db && sleep 2 && pnpm run local:init",
		"local:reset": "docker compose down -v && pnpm run local:setup",
		"local:api": "pnpm run synth && sam local start-api -t cdk.out/Aerostack-ApiStack.template.json --env-vars env/local.json --docker-network aerostack-local-net",
		"local:api-aerostack": "pnpm run synth && sam local start-api -t cdk.out/Aerostack-ApiAerostackStack.template.json --env-vars env/local-apiaerostack.json --port 3001 --docker-network aerostack-local-net",
		"local:api-hiring": "pnpm run synth && sam local start-api -t cdk.out/Aerostack-HiringApiStack.template.json --env-vars env/local-hiring.json --port 3002 --docker-network aerostack-local-net",
		"local:api-central": "AWS_PROFILE=partner-central pnpm run synth && AWS_PROFILE=partner-central sam local start-api -t cdk.out/Aerostack-ApiStack.template.json --env-vars env/local.json --docker-network aerostack-local-net",
		"local:seed": "npx ts-node scripts/seed-and-process-unified.ts --seed-only",
		"local:unified": "npx ts-node scripts/seed-and-process-unified.ts --process-only",
		"local:sync": "npx ts-node scripts/seed-and-process-unified.ts",
		"assign-group": "npx ts-node scripts/assign-group.ts",
		"test:partner-central": "./test-partner-central.sh",
		"test:pc-local": "./test-partner-central.sh local opportunities",
		"test:pc-dev": "./test-partner-central.sh dev opportunities",
		"test:pc-prod": "./test-partner-central.sh prod opportunities"
	},
	"dependencies": {
		"@aws-cdk/aws-amplify-alpha": "^2.0.0-alpha.0",
		"@aws-sdk/client-cognito-identity-provider": "^3.1032.0",
		"@aws-sdk/client-dynamodb": "^3.1032.0",
		"@aws-sdk/client-eventbridge": "^3.1032.0",
		"@aws-sdk/client-partnercentral-selling": "^3.1032.0",
		"@aws-sdk/client-s3": "^3.1032.0",
		"@aws-sdk/client-secrets-manager": "^3.1032.0",
		"@aws-sdk/client-ses": "^3.1032.0",
		"@aws-sdk/client-sts": "^3.1032.0",
		"@aws-sdk/lib-dynamodb": "^3.1032.0",
		"@aws-sdk/s3-request-presigner": "^3.1038.0",
		"@hubspot/api-client": "^13.4.0",
		"adm-zip": "0.5.16",
		"aws-cdk-lib": "^2.232.2",
		"constructs": "^10.4.4",
		"dotenv": "^17.2.3",
		"jose": "^6.2.2",
		"pdf-lib": "1.17.1",
		"xml2js": "0.6.2",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@types/adm-zip": "0.5.7",
		"@types/aws-lambda": "^8.10.145",
		"@types/node": "^20.0.0",
		"@types/xml2js": "0.4.14",
		"esbuild": "^0.25.10",
		"ts-node": "^10.9.2"
	}
}