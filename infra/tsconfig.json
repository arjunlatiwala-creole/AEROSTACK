{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",

    "outDir": "dist",
    "rootDir": "src",

    "composite": true,
    "declaration": true,
    "noEmit": false,

    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "cdk.out", "test", "**/*.test.ts", "dist"]
}
