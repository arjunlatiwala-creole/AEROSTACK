# Copy to repo ROOT as `.linkedin.env` (gitignored):  cp scripts/.linkedin.env.example .linkedin.env
# Replace with YOUR values from LinkedIn Developer Portal → Aerostack app → Auth.

LINKEDIN_CLIENT_ID=
# Primary Client Secret from Auth tab (never commit .linkedin.env — never prefix with VITE_).
LINKEDIN_CLIENT_SECRET=

# MUST match Authorized redirect URLs in LinkedIn Auth, character-for-character.
LINKEDIN_REDIRECT_URI=https://aerostackdev.enterprise.io/oauth/linkedin/callback

# Paste the OAuth `code` once from the browser callback URL (expires in minutes). Then run:
#   node scripts/linkedin-exchange-token.mjs
LINKEDIN_AUTH_CODE=

# Optional: default name for Secrets Manager hint / LINKEDIN_PUT_AWS below
# LINKEDIN_AWS_SECRET_ID=linkedin_content_publish
# LINKEDIN_PUT_AWS=1          # uncomment to pipe JSON to aws secretsmanager put-secret-value (needs aws CLI + creds)
# AWS_REGION=us-east-1
